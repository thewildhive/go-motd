{
  "services": {
    "plex": [
      {
        "name": "Main",
        "url": "https://plex.example.com:32400",
        "token": "your-plex-token-here",
        "enabled": true
      },
      {
        "name": "Backup",
        "url": "https://plex-backup.example.com:32400",
        "token": "your-backup-token-here",
        "enabled": false
      }
    ],
    "jellyfin": [
      {
        "name": "Main",
        "url": "https://jellyfin.example.com:8096",
        "token": "your-jellyfin-token-here",
        "enabled": true
      }
    ],
    "sonarr": [
      {
        "name": "HD",
        "url": "https://sonarr.example.com:8989",
        "api_key": "your-sonarr-api-key-here",
        "enabled": true
      }
    ],
    "radarr": [
      {
        "name": "HD",
        "url": "https://radarr.example.com:7878",
        "api_key": "your-radarr-api-key-here",
        "enabled": true
      }
    ],
    "seerr": [
      {
        "name": "Main",
        "url": "https://seerr.example.com:5055",
        "api_key": "your-seerr-api-key-here",
        "enabled": true
      }
    ]
  },
  "system": {
    "compose_dir": "/opt/apps/compose",
    "tank_mount": "/mnt/tank",
    "network": {
      "interface": "eth0"
    }
  }
}
