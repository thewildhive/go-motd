{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/thewildhive/go-motd.git",
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "minor" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs", "release": false },
          { "type": "style", "release": "patch" },
          { "type": "test", "release": "patch" },
          { "type": "build", "release": "patch" },
          { "type": "ci", "release": false },
          { "type": "chore", "release": false },
          { "breaking": true, "release": "major" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    "@semantic-release/changelog",
    [
      "@semantic-release/github",
      {
        "addReleases": "bottom",
        "draft": false,
        "prerelease": false,
        "successComment": false,
        "failComment": false,
        "assets": [
          "release/*.tar.gz",
          "release/*.zip",
          "release/motd-linux-amd64",
          "release/motd-linux-arm64",
          "release/motd-darwin-amd64",
          "release/motd-darwin-arm64",
          "release/motd-windows-amd64.exe",
          "release/checksums.txt",
          "release/archive-checksums.txt"
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ]
  ]
}
